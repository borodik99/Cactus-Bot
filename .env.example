# Telegram
BOT_API_KEY=PASTE_YOUR_BOT_API_KEY_HERE
ADMIN_CHAT_ID=PASTE_YOUR_ADMIN_CHAT_ID_HERE

# PostgreSQL (для docker-compose)
POSTGRES_USER=PASTE_DB_USER_HERE
POSTGRES_PASSWORD=PASTE_DB_PASSWORD_HERE
POSTGRES_DB=PASTE_DB_NAME_HERE

# pgAdmin (для docker-compose)
PGADMIN_EMAIL=PASTE_PGADMIN_EMAIL_HERE
PGADMIN_PASSWORD=PASTE_PGADMIN_PASSWORD_HERE

# Для локального запуска бота (если не используете docker-compose).
# В docker-compose DATABASE_URL собирается автоматически из POSTGRES_*.
DATABASE_URL=postgresql://PASTE_DB_USER_HERE:PASTE_DB_PASSWORD_HERE@localhost:5432/PASTE_DB_NAME_HERE

# Логирование
LOG_LEVEL=debug

# Повторы Telegram Bot API (rate limits / transient failures)
TELEGRAM_MAX_RETRY_ATTEMPTS=3
TELEGRAM_MAX_RETRY_DELAY_SECONDS=30

# Параллелизм обработки апдейтов (grammY runner).
# 10 — обычно достаточно для небольших/средних нагрузок.
RUNNER_CONCURRENCY=10

